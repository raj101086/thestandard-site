---
import { getCollection, render } from "astro:content";
import PostLayout from "@/layouts/PostLayout.astro";
import BlogCard from "@/components/cards/BlogCard.astro";

export async function getStaticPaths() {
  const postEntries = await getCollection("post");
  return postEntries.map((entry) => ({
    params: { slug: entry.id },
    props: { entry },
  }));
}

const { slug } = Astro.params;
const { entry } = Astro.props;

if (!entry) return Astro.redirect("/404");

const { Content } = await render(entry);

const formattedDate = entry.data.publishDate.toLocaleDateString('en-US', {
  year: 'numeric', month: 'long', day: 'numeric'
});

const wordCount = entry.body?.split(/\s+/).length || 0;
const readingTime = Math.max(1, Math.round(wordCount / 200));

const allPosts = await getCollection("post");
const relatedPosts = allPosts
  .filter(p => p.id !== entry.id)
  .sort((a, b) => {
    const sameCategory = a.data.tags?.[0] === entry.data.tags?.[0];
    const bSameCategory = b.data.tags?.[0] === entry.data.tags?.[0];
    if (sameCategory && !bSameCategory) return -1;
    if (!sameCategory && bSameCategory) return 1;
    return b.data.publishDate.valueOf() - a.data.publishDate.valueOf();
  })
  .slice(0, 3)
  .map(p => ({
    ...p,
    data: { ...p.data, link: `/blog/${p.id}` }
  }));
---

<PostLayout
  title={entry.data.title}
  description={entry.data.description}
  ogImage={entry.data.img}
  ogType="article"
  url={`https://thestandard.co.in/blog/${entry.id}`}
>

  <div id="reading-progress" class="reading-progress"></div>

  <article class="post-page">

    <!-- HEADER -->
    <header class="post-header">
      <div class="post-header-split">
        <div class="post-header-left">
          {entry.data.tags && entry.data.tags.length > 0 && (
            <div class="post-eyebrow">{entry.data.tags[0]}</div>
          )}
          <h1 class="post-title font-brand">{entry.data.title}</h1>
          <div class="post-meta">
            <time datetime={entry.data.publishDate.toISOString()}>{formattedDate}</time>
            <span class="post-meta-sep">·</span>
            <span>{readingTime} min read</span>
          </div>
          {entry.data.description && (
            <p class="post-desc">{entry.data.description}</p>
          )}
        </div>
        {entry.data.img && (
          <div class="post-header-right">
            <img
              src={entry.data.img}
              alt={entry.data.img_alt || entry.data.title}
              class="post-header-img"
              style={entry.data.img_position ? `object-position: ${entry.data.img_position}` : ''}
            />
          </div>
        )}
      </div>
    </header>

    <!-- CONTENT -->
    <div class="post-content-wrap">
      <div class="post-content prose">
        <Content />
      </div>
    </div>

    <!-- AUTHOR BOX -->
    <div class="post-author">
      <div class="post-author-inner">
        <div class="post-author-name">Raj Pillay</div>
        <p class="post-author-bio">Writer, motorcyclist, reader, and curator of The Standard. Based in Pune, India.</p>
      </div>
    </div>

    <!-- BACK LINK -->
    <div class="post-back">
      <a href="/archive" class="post-back-link">← Back to Archive</a>
    </div>

  </article>

  <!-- RELATED POSTS -->
  {relatedPosts.length > 0 && (
    <div class="post-related">
      <div class="post-related-header">
        <span class="post-related-label">Continue Reading</span>
        <div class="post-related-line"></div>
      </div>
      <div class="post-related-grid">
        {relatedPosts.map(post => (
          <BlogCard content={{ ...post.data, ...post }} />
        ))}
      </div>
    </div>
  )}

  <script type="application/ld+json" set:html={JSON.stringify({
    "@context": "https://schema.org",
    "@type": "Article",
    "headline": entry.data.title,
    "description": entry.data.description,
    "image": entry.data.img,
    "datePublished": entry.data.publishDate.toISOString(),
    "author": {
      "@type": "Person",
      "name": "Raj Pillay",
      "url": "https://thestandard.co.in/about"
    },
    "publisher": {
      "@type": "Organization",
      "name": "The Standard",
      "url": "https://thestandard.co.in"
    },
    "url": `https://thestandard.co.in/blog/${entry.id}`
  })} />

</PostLayout>

<style>
  .reading-progress {
    position: fixed;
    top: 0;
    left: 0;
    width: 100%;
    height: 2px;
    background: #B8986A;
    transform: scaleX(0);
    transform-origin: left;
    z-index: 100;
    transition: transform 0.1s linear;
  }

  /* ── HEADER ───────────────────────────────────────────────────── */
  .post-header {
    border-bottom: 0.5px solid #2a2a28;
  }
  .post-header-split {
    display: grid;
    grid-template-columns: 1fr 1fr;
    height: 500px;
  }
  .post-header-left {
    padding: 3rem 2.5rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 0.5px solid #2a2a28;
  }
  .post-header-right {
    overflow: hidden;
    background: #0e0e0c;
  }
  .post-header-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
  }
  .post-eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B8986A;
    margin-bottom: 1rem;
  }
  .post-title {
    font-size: clamp(28px, 4vw, 48px);
    line-height: 1.1;
    font-weight: normal;
    color: #E8E2D6;
    margin-bottom: 1.25rem;
    letter-spacing: -0.01em;
  }
  .post-meta {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #555;
    letter-spacing: 0.08em;
    margin-bottom: 1.5rem;
  }
  .post-meta-sep {
    margin: 0 6px;
    color: #333;
  }
  .post-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.7;
    color: #666;
    margin: 0;
  }

  /* ── CONTENT ──────────────────────────────────────────────────── */
  .post-content-wrap {
    max-width: 680px;
    margin: 0 auto;
    padding: 3.5rem 2rem 4rem;
  }
  .post-content {
    font-family: var(--font-sans);
    font-size: 15px;
    line-height: 1.9;
    color: #888;
  }
  .post-content :global(p) {
    color: #888;
    margin-bottom: 1.5rem;
    font-size: 15px;
    line-height: 1.9;
  }
  .post-content :global(h2) {
    font-family: var(--font-brand);
    font-size: 24px;
    font-weight: normal;
    color: #E8E2D6;
    margin: 2.5rem 0 1rem;
  }
  .post-content :global(h3) {
    font-family: var(--font-brand);
    font-size: 20px;
    font-weight: normal;
    color: #E8E2D6;
    margin: 2rem 0 0.75rem;
  }
  .post-content :global(em) {
    font-style: italic;
    color: #A09890;
  }
  .post-content :global(strong) {
    color: #E8E2D6;
    font-weight: 500;
  }
  .post-content :global(a) {
    color: #B8986A;
    text-decoration: none;
    border-bottom: 0.5px solid #B8986A40;
    transition: border-color 0.2s;
  }
  .post-content :global(a:hover) {
    border-color: #B8986A;
  }
  .post-content :global(blockquote) {
    border-left: 2px solid #B8986A;
    margin: 2rem 0;
    padding: 1rem 1.5rem;
    background: #1e1e1c;
  }
  .post-content :global(blockquote p) {
    color: #B8986A;
    font-style: italic;
    font-size: 17px;
    margin: 0;
  }
  .post-content :global(hr) {
    border: none;
    border-top: 0.5px solid #2a2a28;
    margin: 2.5rem 0;
  }
  .post-content :global(iframe) {
    width: 100%;
    border: 0.5px solid #2a2a28;
    margin: 1.5rem 0;
  }
  .post-content :global(img) {
    width: 100%;
    border-radius: 0;
    margin: 1.5rem 0;
  }

  /* ── AUTHOR BOX ───────────────────────────────────────────────── */
  .post-author {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 2rem 0;
    border-top: 0.5px solid #2a2a28;
  }
  .post-author-inner {
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .post-author-name {
    font-family: var(--font-brand);
    font-size: 16px;
    color: #E8E2D6;
    font-weight: normal;
  }
  .post-author-bio {
    font-family: var(--font-sans);
    font-size: 12px;
    color: #555;
    line-height: 1.7;
    margin: 0;
  }

  /* ── BACK LINK ────────────────────────────────────────────────── */
  .post-back {
    max-width: 680px;
    margin: 0 auto;
    padding: 2rem 2rem 4rem;
    border-top: 0.5px solid #2a2a28;
  }
  .post-back-link {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .post-back-link:hover { color: #B8986A; }

  /* ── RELATED POSTS ────────────────────────────────────────────── */
  .post-related {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 2rem;
    border-top: 0.5px solid #2a2a28;
  }
  .post-related-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .post-related-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .post-related-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }
  .post-related-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── RESPONSIVE ───────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .post-related-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .post-header-split { grid-template-columns: 1fr; height: auto; }
    .post-header-right { order: -1; height: 260px; }
    .post-header-left { border-right: none; padding: 2rem 1.5rem; }
  }
  @media (max-width: 640px) {
    .post-content-wrap { padding: 2.5rem 1.5rem 3rem; }
    .post-back { padding: 1.5rem 1.5rem 3rem; }
    .post-related-grid { grid-template-columns: 1fr; }
    .post-related { padding: 2rem 1.5rem; }
  }
</style>

<script>
  function updateReadingProgress() {
    const bar = document.getElementById('reading-progress');
    if (!bar) return;
    const scrolled = window.scrollY;
    const total = document.documentElement.scrollHeight - window.innerHeight;
    bar.style.transform = `scaleX(${Math.min(scrolled / total, 1)})`;
  }
  window.addEventListener('scroll', updateReadingProgress, { passive: true });
  updateReadingProgress();
</script>