---
import Layout from "@/layouts/Layout.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import BlogCard from "@/components/cards/BlogCard.astro";
import Ticker from "@/components/elements/Ticker.astro";
import { getCollection } from "astro:content";

const POSTS_PER_PAGE = 6;
const currentPage = 1;

// Start Here — manually chosen post IDs
const START_HERE_IDS = [
  "sambar",
  "the-new-abnormal-the-strokes",
  "mashooqa-royal-enfield-interceptor",
];

const allPosts = await getCollection("post");
const startHerePosts = START_HERE_IDS
  .map(id => allPosts.find(p => p.id === id))
  .filter(Boolean)
  .map(p => ({
    ...p,
    data: { ...p.data, link: `/blog/${p.id}` }
  }));
---

<Layout title="The Standard">

  <Ticker />

  <!-- START HERE -->
  {startHerePosts.length > 0 && (
    <div class="start-here-wrap">
      <div class="start-here-header">
        <span class="start-here-label">Start Here</span>
        <div class="start-here-line"></div>
      </div>
      <div class="start-here-grid">
        {startHerePosts.map(post => (
          <BlogCard content={{ ...post.data, ...post }} />
        ))}
      </div>
    </div>
  )}

  <div class="cat-tabs-wrap">
    <div class="cat-tabs">
      <a href="/blog" class="cat-tab active">All Posts</a>
      <a href="/blog/category/fashion" class="cat-tab">Fashion</a>
      <a href="/blog/category/motorcycles" class="cat-tab">Motorcycles</a>
      <a href="/blog/category/film-series" class="cat-tab">Film & Series</a>
      <a href="/blog/category/music" class="cat-tab">Music</a>
      <a href="/blog/category/photography" class="cat-tab">Photography</a>
      <a href="/blog/category/books" class="cat-tab">Books</a>
      <a href="/blog/category/coffee-food" class="cat-tab">Coffee & Food</a>
      <a href="/blog/category/travel" class="cat-tab">Travel</a>
      <a href="/blog/category/watches" class="cat-tab">Watches</a>
    </div>
  </div>

  <div class="posts-wrap">
    <div class="section-header">
      <span class="section-label">TheStandard</span>
      <div class="section-line"></div>
    </div>

    <BlogSection
      title="All Articles"
      listPage={true}
      pagination={{ enable: true, currentPage: currentPage }}
      postsPerPage={POSTS_PER_PAGE}
    />
  </div>

</Layout>

<style>
  .cat-tabs-wrap {
    border-bottom: 0.5px solid #2a2a28;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-tabs-wrap::-webkit-scrollbar { display: none; }
  .cat-tabs {
    display: flex;
    padding: 0 4rem;
    min-width: max-content;
  }
  .cat-tab {
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    padding: 14px 18px 12px;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .cat-tab:hover { color: #999; }
  .cat-tab.active {
    color: #E8E2D6;
    border-bottom: 2px solid #B8986A;
  }

  /* START HERE */
  .start-here-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 4rem;
    border-bottom: 0.5px solid #2a2a28;
  }
  .start-here-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .start-here-label {
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .start-here-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }
  .start-here-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  .posts-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.5rem 4rem 5rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .section-label {
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }

  @media (max-width: 1024px) {
    .start-here-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .cat-tabs { padding: 0 1.5rem; }
    .posts-wrap { padding: 2.5rem 1.5rem 4rem; }
    .start-here-wrap { padding: 2rem 1.5rem; }
    .start-here-grid { grid-template-columns: 1fr; }
  }
</style>