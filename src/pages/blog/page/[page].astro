---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";
import BlogSection from "@/components/sections/BlogSection.astro";

export const POSTS_PER_PAGE = 6;

export async function getStaticPaths() {
  const allPosts = await getCollection("post");
  const posts = allPosts.sort(
    (a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf()
  );
  const totalPages = Math.ceil(posts.length / POSTS_PER_PAGE);
  return Array.from({ length: totalPages }, (_, i) => ({
    params: { page: (i + 1).toString() },
    props: { page: (i + 1).toString() }
  }));
}

const { page } = Astro.props;
const currentPage = parseInt(page);
---

<Layout title="The Standard">

  <div class="ticker-wrap">
    <div class="ticker-inner">
      <span>Recently: Setting up TheStandard</span>
      <span class="sep">·</span>
      <span>Location: Pune, India</span>
      <span class="sep">·</span>
      <span>Categories: Fashion · Motorcycles · Film · Music · Photography · Books · Coffee · Travel · Watches</span>
      <span class="sep">·</span>
      <span>Status: First posts coming soon</span>
      <span class="gap"></span>
      <span>Recently: Setting up TheStandard</span>
      <span class="sep">·</span>
      <span>Location: Pune, India</span>
      <span class="sep">·</span>
      <span>Categories: Fashion · Motorcycles · Film · Music · Photography · Books · Coffee · Travel · Watches</span>
      <span class="sep">·</span>
      <span>Status: First posts coming soon</span>
    </div>
  </div>

  <div class="cat-tabs-wrap">
    <div class="cat-tabs">
      <a href="/blog" class="cat-tab active">All Posts</a>
      <a href="/blog/category/fashion" class="cat-tab">Fashion</a>
      <a href="/blog/category/motorcycles" class="cat-tab">Motorcycles</a>
      <a href="/blog/category/film-series" class="cat-tab">Film & Series</a>
      <a href="/blog/category/music" class="cat-tab">Music</a>
      <a href="/blog/category/photography" class="cat-tab">Photography</a>
      <a href="/blog/category/books" class="cat-tab">Books</a>
      <a href="/blog/category/coffee-food" class="cat-tab">Coffee & Food</a>
      <a href="/blog/category/travel" class="cat-tab">Travel</a>
      <a href="/blog/category/watches" class="cat-tab">Watches</a>
    </div>
  </div>

  <div class="posts-wrap">
    <div class="section-header">
      <span class="section-label">TheStandard</span>
      <div class="section-line"></div>
    </div>

    <BlogSection
      title="All Articles"
      listPage={true}
      pagination={{ enable: true, currentPage: currentPage }}
      postsPerPage={POSTS_PER_PAGE}
    />
  </div>

</Layout>

<style>
  .ticker-wrap {
    background: #141412;
    border-bottom: 0.5px solid #2a2a28;
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }
  .ticker-inner {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    animation: ticker 32s linear infinite;
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .ticker-inner .sep { color: #4a4840; }
  .ticker-inner .gap { display: inline-block; width: 80px; }
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  .cat-tabs-wrap {
    border-bottom: 0.5px solid #2a2a28;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-tabs-wrap::-webkit-scrollbar { display: none; }
  .cat-tabs {
    display: flex;
    padding: 0 4rem;
    min-width: max-content;
  }
  .cat-tab {
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    padding: 14px 18px 12px;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .cat-tab:hover { color: #999; }
  .cat-tab.active {
    color: #E8E2D6;
    border-bottom: 2px solid #B8986A;
  }

  .posts-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.5rem 4rem 5rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .section-label {
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .section-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }

  @media (max-width: 768px) {
    .cat-tabs { padding: 0 1.5rem; }
    .posts-wrap { padding: 2.5rem 1.5rem 4rem; }
  }
</style>