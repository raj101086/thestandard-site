---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("post");
const allPhoto = await getCollection("photography");
const postCount = allPosts.length + allPhoto.length;
const categories = [...new Set(allPosts.flatMap(p => p.data.tags || []))];
---

<Layout title="About — The Standard">

  <!-- PAGE HEADER -->
  <div class="about-header">
    <div class="about-eyebrow">About</div>
    <h1 class="about-title font-brand">The<em>Standard</em></h1>
    <p class="about-subtitle">A personal editorial journal. Pune, India.</p>
  </div>

  <!-- MAIN CONTENT -->
  <div class="about-body">

    <!-- LEFT COL -->
    <div class="about-left">

      <div class="about-block">
        <div class="block-label">The name</div>
        <p class="block-text">
          Not average. Not a rubric. More like a quiet insistence that the things you spend time on should actually be worth it.
        </p>
      </div>

      <div class="about-block">
        <div class="block-label">What this is</div>
        <p class="block-text">
          A place to write about the things I genuinely care about. Motorcycles, music, film, watches, books, coffee, travel. No posting schedule, no content calendar. Just when something is worth writing down.
        </p>
      </div>

      <div class="about-block">
        <div class="block-label">Why it exists</div>
        <p class="block-text">
          I got tired of good recommendations disappearing into group chats. A watch I loved, a book that stayed with me, a song I kept coming back to. Written here so they don't just vanish.
        </p>
      </div>

      <div class="about-block">
        <div class="block-label">Get in touch</div>
        <a href="mailto:thestandardblogpost@gmail.com" class="about-email">
          thestandardblogpost@gmail.com →
        </a>
      </div>

    </div>

    <!-- RIGHT COL — stats + categories -->
    <div class="about-right">

      <div class="about-stat-block">
        <div class="stat-row">
          <span class="stat-num font-brand">{postCount}</span>
          <span class="stat-label">Posts published</span>
        </div>
        <div class="stat-row">
          <span class="stat-num font-brand">{categories.length}</span>
          <span class="stat-label">Categories covered</span>
        </div>
        <div class="stat-row">
          <span class="stat-num font-brand">2026</span>
          <span class="stat-label">Est. Pune, India</span>
        </div>
      </div>

      <div class="about-cats">
        <div class="block-label">Topics</div>
        <div class="cats-grid">
          {["Music", "Motorcycles", "Film & Series", "Watches", "Books", "Photography", "Coffee & Food", "Travel", "Fashion"].map(cat => (
            <a href={`/archive?category=${encodeURIComponent(cat)}`} class="cat-pill">{cat}</a>
          ))}
        </div>
      </div>

      <div class="about-logo-block">
        <div class="about-logo-box">
          <img src="/logo.png" alt="The Standard" class="about-logo-img" />
        </div>
        <span class="about-logo-label">© 2026 The<em>Standard</em></span>
      </div>

    </div>

  </div>

</Layout>

<style>
  /* ── HEADER ───────────────────────────────────────────────────── */
  .about-header {
    padding: 5rem 4rem 4rem;
    border-bottom: 0.5px solid #2a2a28;
  }
  .about-eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B8986A;
    margin-bottom: 1.25rem;
  }
  .about-title em {
    font-style: italic;
    color: #B8986A;
  }
  .about-title {
    font-size: clamp(44px, 5vw, 72px);
    line-height: 1.0;
    font-weight: normal;
    color: #E8E2D6;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }
  .about-subtitle {
    font-family: var(--font-sans);
    font-size: 13px;
    color: #555;
    letter-spacing: 0.06em;
  }

  /* ── BODY GRID ────────────────────────────────────────────────── */
  .about-body {
    display: grid;
    grid-template-columns: 1fr 1fr;
    min-height: 60vh;
  }

  /* ── LEFT ─────────────────────────────────────────────────────── */
  .about-left {
    padding: 4rem;
    border-right: 0.5px solid #2a2a28;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }
  .about-block { display: flex; flex-direction: column; gap: 10px; }
  .block-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.2em;
    text-transform: uppercase;
    color: #555;
  }
  .block-text {
    font-family: var(--font-sans);
    font-size: 14px;
    line-height: 1.85;
    color: #888;
    max-width: 480px;
  }
  .about-email {
    font-family: var(--font-sans);
    font-size: 13px;
    color: #E8E2D6;
    text-decoration: none;
    border-bottom: 0.5px solid #B8986A;
    padding-bottom: 2px;
    display: inline-block;
    transition: color 0.2s;
  }
  .about-email:hover { color: #B8986A; }

  /* ── RIGHT ────────────────────────────────────────────────────── */
  .about-right {
    padding: 4rem;
    display: flex;
    flex-direction: column;
    gap: 3rem;
  }

  /* Stats */
  .about-stat-block {
    display: flex;
    flex-direction: column;
    gap: 1.5rem;
    padding-bottom: 3rem;
    border-bottom: 0.5px solid #2a2a28;
  }
  .stat-row {
    display: flex;
    align-items: baseline;
    gap: 1rem;
  }
  .stat-num {
    font-size: 48px;
    line-height: 1;
    color: #E8E2D6;
    font-weight: normal;
    letter-spacing: -0.02em;
  }
  .stat-label {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #444;
  }

  /* Categories */
  .about-cats { display: flex; flex-direction: column; gap: 14px; }
  .cats-grid {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-top: 4px;
  }
  .cat-pill {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #666;
    border: 0.5px solid #2a2a28;
    padding: 6px 12px;
    text-decoration: none;
    transition: border-color 0.2s, color 0.2s;
  }
  .cat-pill:hover { border-color: #B8986A; color: #B8986A; }

  /* Logo block */
  .about-logo-block {
    margin-top: auto;
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .about-logo-box {
    display: inline-block;
    background: #E8E2D6;
    padding: 4px 8px;
    width: fit-content;
  }
  .about-logo-img { height: 28px; width: auto; display: block; }
  .about-logo-label em {
    font-style: italic;
    color: #B8986A;
  }
  .about-logo-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.1em;
    color: #333;
  }

  /* ── RESPONSIVE ───────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .about-header { padding: 3rem 1.5rem 2.5rem; }
    .about-body { grid-template-columns: 1fr; }
    .about-left { padding: 2.5rem 1.5rem; border-right: none; border-bottom: 0.5px solid #2a2a28; }
    .about-right { padding: 2.5rem 1.5rem; }
    .stat-num { font-size: 36px; }
  }
</style>