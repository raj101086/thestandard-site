---
import { Mail } from "@lucide/astro";
import Layout from "@/layouts/Layout.astro";
import Toc from "@/components/widgets/Toc.astro";

// Minimal TOC
const headings = [
  { depth: 2, slug: "about-the-standard", text: "About The Standard" },
];

const filtered = headings.filter(h => h.depth <= 3);
---

<Layout title="About The Standard">

  <!-- Mobile TOC -->
  <div class="block lg:hidden px-7 pt-6">
    <Toc headings={filtered} />
  </div>

  <!-- Main container -->
  <div class="relative site-container mx-auto my-8">
    <div class="flex flex-col lg:flex-row gap-8 lg:gap-12 xl:gap-16">

      <!-- Left TOC -->
      <aside class="relative hidden lg:block lg:w-40 xl:w-50 flex-shrink-0">
        <div class="toc-sticky-wrapper">
          <Toc headings={filtered} />
        </div>
      </aside>

      <!-- Main Content -->
      <main class="relative flex-1 min-w-0 w-full lg:max-w-none">

        <!-- Heading -->
        <div
          class="w-full"
          data-aos="fade-up-xs"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <h2
            id="about-the-standard"
            class="text-2xl font-brand tracking-tight sm:text-3xl lg:text-4xl"
          >
            About The Standard
          </h2>

          <div class="w-full border-b border-dashed border-b-gray-200 dark:border-b-neutral-700 mt-4 mb-10"></div>
        </div>

        <!-- Logo -->
        <div
          class="flex items-center gap-4 mb-12"
          data-aos="fade-up-xs"
          data-aos-delay="100"
          data-aos-duration="500"
          data-aos-once="true"
        >
          <img
            src="/assets/avatar.png"
            alt="The Standard"
            class="w-14 h-14 rounded-full"
          />

          <span class="font-brand text-[28px] text-neutral-800 dark:text-neutral-100">
            The Standard
          </span>
        </div>

        <!-- Intro -->
        <div class="max-w-3xl">

          <h3
            class="text-2xl font-semibold mb-6 text-neutral-900 dark:text-neutral-100"
            data-aos="fade-up-xs"
            data-aos-delay="150"
            data-aos-duration="500"
            data-aos-once="true"
          >
            A personal editorial journal.
          </h3>

          <p
            class="mb-6 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
            data-aos="fade-up-xs"
            data-aos-delay="200"
            data-aos-duration="500"
            data-aos-once="true"
          >
            Built around music, motorcycles, film, watches, travel and everyday aesthetics — this is a curated space for observations, recommendations and stories collected along the way.
          </p>

          <p
            class="mb-10 text-lg leading-relaxed text-neutral-700 dark:text-neutral-300"
            data-aos="fade-up-xs"
            data-aos-delay="250"
            data-aos-duration="500"
            data-aos-once="true"
          >
            Part publication, part archive and part notebook — created for people who appreciate thoughtful design, mechanical beauty and cinematic experiences.
          </p>

          <!-- Contact -->
          <div
            class="mt-10"
            data-aos="fade-up-xs"
            data-aos-delay="300"
            data-aos-duration="500"
            data-aos-once="true"
          >
            <a
              href="mailto:thestandardblogpost@gmail.com"
              class="inline-flex items-center gap-2 px-6 py-3 rounded-xl border border-neutral-300 dark:border-neutral-700 hover:bg-neutral-100 dark:hover:bg-neutral-800 transition"
            >
              <Mail size={18} />
              Get in touch
            </a>
          </div>

        </div>

      </main>
    </div>
  </div>
</Layout>

<style>
.toc-sticky-wrapper {
  position: sticky;
  top: 8rem;
}
</style>