---
import Layout from "@/layouts/Layout.astro";
import BlogSection from "@/components/sections/BlogSection.astro";
import BlogCard from "@/components/cards/BlogCard.astro";
import { getCollection } from "astro:content";

const POSTS_PER_PAGE = 6;
const currentPage = 1;

const allPosts = await getCollection("post");
const allPhoto = await getCollection("photography");

const latestPosts = [
  ...allPosts.map(post => ({
    title: post.data.title,
    tags: post.data.tags || [],
    img: post.data.img || null,
    link: `/blog/${post.id}`,
    date: post.data.publishDate,
  })),
  ...allPhoto.map(s => ({
    title: s.data.title,
    tags: ["Photography"],
    img: s.data.cover || null,
    link: `/photography/${s.id}`,
    date: s.data.date,
  })),
]
  .sort((a, b) => b.date.valueOf() - a.date.valueOf())
  .slice(0, 5);

const START_HERE_IDS = [
  "sambar",
  "the-new-abnormal-the-strokes",
  "mashooqa-royal-enfield-interceptor",
];

const startHerePosts = START_HERE_IDS
  .map(id => allPosts.find(p => p.id === id))
  .filter((p): p is NonNullable<typeof p> => p !== undefined)
  .map(p => ({
    ...p,
    data: { ...p.data, link: `/blog/${p.id}` }
  }));
---

<Layout title="The Standard">

  <!-- ─── TICKER ─────────────────────────────────────────────────── -->
  <div class="ticker-wrap">
    <div class="ticker-inner">
      {latestPosts.map(post => (
        <>
          <span class="ticker-label">New</span>
          <span>{post.tags[0] && <span class="ticker-cat">{post.tags[0]}</span>}{post.title}</span>
          <span class="sep">·</span>
        </>
      ))}
      <span>Location: Pune, India</span>
      <span class="sep">·</span>
      <span>thestandard.co.in</span>
      <span class="gap"></span>
      {latestPosts.map(post => (
        <>
          <span class="ticker-label">New</span>
          <span>{post.tags[0] && <span class="ticker-cat">{post.tags[0]}</span>}{post.title}</span>
          <span class="sep">·</span>
        </>
      ))}
      <span>Location: Pune, India</span>
      <span class="sep">·</span>
      <span>thestandard.co.in</span>
    </div>
  </div>

  <!-- ─── HERO ───────────────────────────────────────────────────── -->
  <div class="hero-grid">

    <div class="hero-left">
      <div class="hero-eyebrow">
        Est. 2026
        <span class="eyebrow-divider">—</span>
        <span class="eyebrow-location">Pune, India</span>
      </div>

      <h1 class="font-brand hero-h1">
        Things worth<br>
        <em>paying attention to.</em>
      </h1>

      <p class="hero-desc">
        Motorcycles, fashion, film, music, photography, books, coffee,
        and travel. Posted when something is genuinely worth sharing.
      </p>

      <a href="/archive" class="hero-cta">Browse the Archive →</a>
    </div>

    <!-- CAROUSEL -->
    <div class="hero-right">
      <div class="carousel-viewport" id="carouselViewport">
        {latestPosts.map((post, i) => (
          <div class={`carousel-slide ${i === 0 ? "active" : ""}`} data-index={i}>
            <a href={post.link} class="carousel-link">
              {post.img ? (
                <img src={post.img} alt={post.title} class="carousel-img" />
              ) : (
                <div class="carousel-placeholder"></div>
              )}
              <div class="carousel-overlay">
                <span class="carousel-cat">{post.tags[0] || ""}</span>
                <span class="carousel-title font-brand">{post.title}</span>
              </div>
            </a>
          </div>
        ))}
      </div>

      {latestPosts.length > 1 && (
        <div class="carousel-dots" id="carouselDots">
          {latestPosts.map((_, i) => (
            <button class={`carousel-dot ${i === 0 ? "active" : ""}`} data-dot={i} aria-label={`Slide ${i + 1}`}></button>
          ))}
        </div>
      )}
    </div>

  </div>

  <!-- ─── START HERE ─────────────────────────────────────────────── -->
  {startHerePosts.length > 0 && (
    <div class="start-here-wrap">
      <div class="start-here-header">
        <span class="start-here-label">Start Here</span>
        <div class="start-here-line"></div>
      </div>
      <div class="start-here-grid">
        {startHerePosts.map(post => (
          <BlogCard content={{ ...post.data, ...post }} />
        ))}
      </div>
    </div>
  )}

  <!-- ─── CATEGORY TABS ──────────────────────────────────────────── -->
  <div class="cat-tabs-wrap">
    <div class="cat-tabs">
      <a href="/archive" class="cat-tab active">All Posts</a>
      <a href="/archive?category=Fashion" class="cat-tab">Fashion</a>
      <a href="/archive?category=Motorcycles" class="cat-tab">Motorcycles</a>
      <a href="/archive?category=Film+%26+Series" class="cat-tab">Film & Series</a>
      <a href="/archive?category=Music" class="cat-tab">Music</a>
      <a href="/archive?category=Photography" class="cat-tab">Photography</a>
      <a href="/archive?category=Books" class="cat-tab">Books</a>
      <a href="/archive?category=Coffee+%26+Food" class="cat-tab">Coffee & Food</a>
      <a href="/archive?category=Travel" class="cat-tab">Travel</a>
      <a href="/archive?category=Watches" class="cat-tab">Watches</a>
    </div>
  </div>

  <!-- ─── POSTS ──────────────────────────────────────────────────── -->
  <div class="posts-wrap">
    <div class="section-header">
      <span class="section-label">TheStandard</span>
      <div class="section-line"></div>
    </div>

    <BlogSection
      title=""
      listPage={true}
      pagination={{ enable: true, currentPage: currentPage }}
      postsPerPage={POSTS_PER_PAGE}
    />
  </div>

</Layout>

<style>
  /* ── TICKER ──────────────────────────────────────────────────── */
  .ticker-wrap {
    background: #141412;
    border-bottom: 0.5px solid #2a2a28;
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }
  .ticker-inner {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    animation: ticker 32s linear infinite;
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .ticker-inner .sep { color: #4a4840; }
  .ticker-label {
    color: #555;
    font-size: 9px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    border: 0.5px solid #333;
    padding: 1px 6px;
    margin-right: 4px;
  }
  .ticker-cat {
    color: #666;
    margin-right: 6px;
    font-size: 9px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
  }
  .ticker-inner .gap { display: inline-block; width: 80px; }
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }

  /* ── HERO ────────────────────────────────────────────────────── */
  .hero-grid {
    display: grid;
    grid-template-columns: 1fr 1fr;
    border-bottom: 0.5px solid #2a2a28;
    align-items: stretch;
  }
  .hero-left {
    padding: 5rem 3rem 5rem 4rem;
    display: flex;
    flex-direction: column;
    justify-content: center;
    border-right: 0.5px solid #2a2a28;
  }
  .hero-eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #555;
    margin-bottom: 1.5rem;
    display: flex;
    align-items: center;
    gap: 8px;
  }
  .eyebrow-divider { color: #333; }
  .eyebrow-location { color: #B8986A; }
  .hero-h1 {
    font-size: clamp(38px, 4.5vw, 58px);
    line-height: 1.08;
    font-weight: normal;
    color: #E8E2D6;
    margin-bottom: 1.5rem;
    letter-spacing: -0.01em;
  }
  .hero-h1 em { font-style: italic; color: #B8986A; }
  .hero-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.9;
    color: #666;
    max-width: 380px;
    margin-bottom: 2.5rem;
  }
  .hero-cta {
    display: inline-block;
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    border: 1px solid #3a3a38;
    color: #E8E2D6;
    padding: 13px 26px;
    background: transparent;
    text-decoration: none;
    align-self: flex-start;
    transition: border-color 0.2s, color 0.2s;
  }
  .hero-cta:hover { border-color: #B8986A; color: #B8986A; }

  /* ── CAROUSEL ────────────────────────────────────────────────── */
  .hero-right {
    position: relative;
    background: #141412;
  }
  .carousel-viewport {
    position: relative;
    width: 100%;
    aspect-ratio: 3/2;
    overflow: hidden;
  }
  .carousel-slide {
    position: absolute;
    inset: 0;
    opacity: 0;
    transition: opacity 0.6s ease;
    pointer-events: none;
  }
  .carousel-slide.active {
    opacity: 1;
    pointer-events: auto;
  }
  .carousel-link {
    display: block;
    width: 100%;
    height: 100%;
    text-decoration: none;
  }
  .carousel-img {
    width: 100%;
    height: 100%;
    object-fit: cover;
    object-position: center;
    display: block;
    transition: transform 0.8s ease;
  }
  .carousel-slide.active:hover .carousel-img { transform: scale(1.03); }
  .carousel-placeholder {
    width: 100%;
    height: 100%;
    background: #1a1a18;
  }
  .carousel-overlay {
    position: absolute;
    bottom: 0;
    left: 0;
    right: 0;
    padding: 2.5rem 2rem 2rem;
    background: linear-gradient(to top, rgba(0,0,0,0.85) 0%, rgba(0,0,0,0.3) 60%, transparent 100%);
    display: flex;
    flex-direction: column;
    gap: 6px;
  }
  .carousel-cat {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.18em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .carousel-title {
    font-size: 22px;
    font-weight: normal;
    color: #E8E2D6;
    line-height: 1.2;
  }
  .carousel-dots {
    position: absolute;
    bottom: 1.25rem;
    right: 1.25rem;
    display: flex;
    gap: 6px;
    z-index: 10;
  }
  .carousel-dot {
    width: 6px;
    height: 6px;
    border-radius: 50%;
    background: #444;
    border: none;
    cursor: pointer;
    padding: 0;
    transition: background 0.2s, transform 0.2s;
  }
  .carousel-dot.active { background: #B8986A; transform: scale(1.3); }

  /* ── START HERE ──────────────────────────────────────────────── */
  .start-here-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 4rem;
    border-bottom: 0.5px solid #2a2a28;
  }
  .start-here-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 2rem;
  }
  .start-here-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .start-here-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }
  .start-here-grid {
    display: grid;
    grid-template-columns: repeat(3, 1fr);
    gap: 1.5rem;
  }

  /* ── CATEGORY TABS ───────────────────────────────────────────── */
  .cat-tabs-wrap {
    border-bottom: 0.5px solid #2a2a28;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .cat-tabs-wrap::-webkit-scrollbar { display: none; }
  .cat-tabs {
    display: flex;
    padding: 0 4rem;
    min-width: max-content;
  }
  .cat-tab {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    padding: 14px 18px 12px;
    text-decoration: none;
    border-bottom: 2px solid transparent;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .cat-tab:hover { color: #999; }
  .cat-tab.active { color: #E8E2D6; border-bottom: 2px solid #B8986A; }

  /* ── POSTS SECTION ───────────────────────────────────────────── */
  .posts-wrap {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3.5rem 4rem 5rem;
  }
  .section-header {
    display: flex;
    align-items: center;
    gap: 1.25rem;
    margin-bottom: 3rem;
  }
  .section-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #444;
    white-space: nowrap;
  }
  .section-line { flex: 1; height: 0.5px; background: #2a2a28; }

  /* ── RESPONSIVE ──────────────────────────────────────────────── */
  @media (max-width: 1024px) {
    .start-here-grid { grid-template-columns: repeat(2, 1fr); }
  }
  @media (max-width: 768px) {
    .hero-grid { grid-template-columns: 1fr; }
    .hero-left { padding: 3rem 1.5rem; border-right: none; }
    .cat-tabs { padding: 0 1.5rem; }
    .posts-wrap { padding: 2.5rem 1.5rem 4rem; }
    .start-here-wrap { padding: 2rem 1.5rem; }
    .start-here-grid { grid-template-columns: 1fr; }
  }
</style>

<script>
  const slides = document.querySelectorAll<HTMLElement>('.carousel-slide');
  const dots = document.querySelectorAll<HTMLButtonElement>('.carousel-dot');
  let current = 0;
  let timer: number;

  function goTo(index: number) {
    slides[current]?.classList.remove('active');
    dots[current]?.classList.remove('active');
    current = index;
    slides[current]?.classList.add('active');
    dots[current]?.classList.add('active');
  }

  function next() {
    goTo((current + 1) % slides.length);
  }

  function startTimer() {
    timer = window.setInterval(next, 4000);
  }

  dots.forEach((dot, i) => {
    dot.addEventListener('click', () => {
      window.clearInterval(timer);
      goTo(i);
      startTimer();
    });
  });

  if (slides.length > 1) startTimer();
</script>