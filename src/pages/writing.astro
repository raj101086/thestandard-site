---
import Layout from "@/layouts/Layout.astro";
---

<Layout
  title="Writing | The Standard"
  description="Notes on music, motorcycles, film, watches, travel and the things worth paying attention to."
>

  <section class="site-container px-4 py-24 max-w-4xl mx-auto">

    <h1 class="text-5xl md:text-6xl font-brand text-pri mb-6">
      Writing
    </h1>

    <p class="text-lg text-neutral-700 dark:text-neutral-300 mb-16 max-w-2xl">
      Notes, recommendations, observations and essays on music, motorcycles,
      film, watches, travel and everyday aesthetics.
    </p>

    <div class="space-y-10">

      <article class="border-b border-neutral-200 pb-10">
        <p class="text-sm text-neutral-500 mb-2">
          MUSIC
        </p>

        <h2 class="text-3xl font-brand mb-3">
          Familiar — Agnes Obel
        </h2>

        <p class="text-neutral-700 dark:text-neutral-300">
          First heard while watching Dark on Netflix. Haunting,
          cinematic and strangely hypnotic.
        </p>
      </article>

      <article class="border-b border-neutral-200 pb-10">
        <p class="text-sm text-neutral-500 mb-2">
          MOTORCYCLES
        </p>

        <h2 class="text-3xl font-brand mb-3">
          Sunday Morning Ride Notes
        </h2>

        <p class="text-neutral-700 dark:text-neutral-300">
          Empty roads, cold starts and the strange clarity that only comes
          with riding early in the morning.
        </p>
      </article>

    </div>

  </section>

</Layout>