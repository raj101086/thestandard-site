---
import Meta from './Meta.astro';
import Footer from "@/components/sections/Footer.astro";
import Header from "@/components/sections/Header.astro";
import TrackGa from "@/components/widgets/TrackGa.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  url?: string;
}

const { title, description, keywords, ogImage, ogType, url } = Astro.props;

import "../styles/global.css";
import "aos/dist/aos.css";
import "../styles/aos-custom.css";
import '../styles/article.css';
import '../styles/article-enhancements.css';
---

<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <Meta
      title={title}
      description={description}
      keywords={keywords}
      ogImage={ogImage}
      ogType={ogType}
      url={url}
    />
    <TrackGa />
    <script is:inline>
      if (typeof Storage !== 'undefined') {
        if (localStorage.getItem('dark_mode') && localStorage.getItem('dark_mode') == 'true') {
          document.documentElement.classList.add('dark')
        }
      }
    </script>
    <link rel="icon" type="image/x-icon" href="/favicon.png" />
    <script is:inline async src="https://www.googletagmanager.com/gtag/js?id=G-FDY7BJEL0S"></script>
    <script is:inline>
      window.dataLayer = window.dataLayer || [];
      function gtag(){dataLayer.push(arguments);}
      gtag('js', new Date());
      gtag('config', 'G-FDY7BJEL0S');
    </script>
  </head>
  <body class="antialiased bg-bg-primary dark:bg-bg-primary-dark max-w-full overflow-x-hidden">
    <Header />
    <slot />
    <Footer />
    <script src="../assets/js/main.js"></script>
  </body>
</html>