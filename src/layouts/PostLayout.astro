---
import Layout from "@/layouts/Layout.astro";

interface Props {
  title?: string;
  description?: string;
  keywords?: string;
  ogImage?: string;
  ogType?: string;
  url?: string;
}

const { title, description, keywords, ogImage, ogType, url } = Astro.props;
---

<Layout
  title={title}
  description={description}
  keywords={keywords}
  ogImage={ogImage}
  ogType={ogType}
  url={url}
>
  <main class="post-wrapper">
    <slot />
  </main>
</Layout>