---
const items = [
  "Recently: 10 posts and counting",
  "Location: Pune, India",
  "Categories: Fashion · Motorcycles · Film · Music · Photography · Books · Coffee · Travel · Watches",
  "Status: Active",
];

const doubled = [...items, ...items];
---

<div class="ticker-wrap">
  <div class="ticker-inner">
    {doubled.map((item, i) => (
      <>
        <span>{item}</span>
        {i !== doubled.length - 1 && <span class="sep">·</span>}
      </>
    ))}
  </div>
</div>

<style>
  .ticker-wrap {
    background: #141412;
    border-bottom: 0.5px solid #2a2a28;
    overflow: hidden;
    white-space: nowrap;
    padding: 8px 0;
  }
  .ticker-inner {
    display: inline-flex;
    align-items: center;
    gap: 14px;
    animation: ticker 32s linear infinite;
    font-family: var(--font-sans, 'Helvetica Neue', sans-serif);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .ticker-inner .sep { color: #4a4840; }
  @keyframes ticker {
    0%   { transform: translateX(0); }
    100% { transform: translateX(-50%); }
  }
</style>