---
const { content, layout = "vertical", "data-aos": dataAos, "data-aos-delay": dataAosDelay } = Astro.props;

const {
  title,
  description,
  publishDate,
  tags = [] as string[],
  img,
  img_alt,
  slug,
  link
} = content;

const formattedDate = new Date(publishDate).toLocaleDateString('en-US', {
  year: 'numeric',
  month: 'short',
  day: 'numeric'
});

const postLink = link || `/blog/${slug}`;
const isHorizontal = layout === "horizontal";
---

<article
  class:list={[
    "group relative overflow-hidden bg-[#222220] border border-[#2A2A28] transition-all duration-500 hover:border-[#B8986A]/40",
    { "md:flex md:items-center": isHorizontal }
  ]}
  data-aos={dataAos}
  data-aos-delay={dataAosDelay}
>
  <!-- Image container -->
  <div
    class:list={[
      "relative overflow-hidden",
      isHorizontal ? "md:w-1/2" : "aspect-[3/2]"
    ]}
  >
    {img ? (
      <img
        src={img}
        alt={img_alt || `Related to ${title}`}
        loading="lazy"
        class="w-full h-full object-cover transition-transform duration-700 group-hover:scale-105"
      />
    ) : (
      <div class="w-full h-full bg-[#1a1a18] flex items-center justify-center aspect-[3/2]">
        <svg xmlns="http://www.w3.org/2000/svg" width="40" height="40" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1" stroke-linecap="round" stroke-linejoin="round" class="text-[#333]">
          <rect width="18" height="18" x="3" y="3" rx="2" ry="2"></rect>
          <circle cx="9" cy="9" r="2"></circle>
          <path d="m21 15-3.086-3.086a2 2 0 0 0-2.828 0L6 21"></path>
        </svg>
      </div>
    )}

    <!-- Hover overlay -->
    <div class="absolute inset-0 bg-gradient-to-t from-black/70 via-black/20 to-transparent opacity-0 group-hover:opacity-100 transition-all duration-500 flex items-center justify-center">
      <span class="w-12 h-12 bg-[#B8986A] flex items-center justify-center transform translate-y-6 opacity-0 group-hover:translate-y-0 group-hover:opacity-100 transition-all duration-500">
        <svg xmlns="http://www.w3.org/2000/svg" width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" class="text-[#1C1C1A]">
          <path d="M7 7h10v10"></path>
          <path d="M7 17 17 7"></path>
        </svg>
      </span>
    </div>

    <a class="absolute inset-0 z-10" href={postLink}>
      <span class="sr-only">Read {title}</span>
    </a>
  </div>

  <!-- Content -->
  <div class:list={[
    "p-5 flex flex-col",
    isHorizontal ? "md:w-1/2 md:p-8" : ""
  ]}>

    <!-- Date + tag -->
    <div class="flex items-center gap-3 mb-4">
      <time class="font-sans text-[10px] tracking-[0.12em] uppercase text-[#555]">
        {formattedDate}
      </time>
      {tags && tags.length > 0 && (
        <>
          <span class="text-[#333]">·</span>
          <span class="font-sans text-[10px] tracking-[0.12em] uppercase text-[#B8986A]">
            {tags[0]}
          </span>
        </>
      )}
    </div>

    <!-- Title -->
    <a href={postLink}>
      <h2 class:list={[
        "font-brand text-[#E8E2D6] mb-3 leading-tight transition-colors duration-300 group-hover:text-[#B8986A] line-clamp-2",
        isHorizontal ? "text-3xl" : "text-xl"
      ]}>
        {title}
      </h2>
    </a>

    <!-- Description -->
    {description && (
      <p class="font-sans text-[#666] text-sm leading-relaxed line-clamp-3 mb-5">
        {description}
      </p>
    )}

    <!-- Read More -->
    <div class="mt-auto pt-3 border-t border-[#2A2A28]">
      <a
        href={postLink}
        class="inline-flex items-center gap-2 font-sans text-[10px] tracking-[0.12em] uppercase text-[#888] hover:text-[#B8986A] transition-colors duration-300 group/link"
      >
        <span>Read More</span>
        <svg xmlns="http://www.w3.org/2000/svg" width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" class="transition-transform duration-300 group-hover/link:translate-x-1">
          <line x1="5" y1="12" x2="19" y2="12"></line>
          <polyline points="12 5 19 12 12 19"></polyline>
        </svg>
      </a>
    </div>

  </div>
</article>