---

<footer class="ts-footer">
  <div class="footer-bar">

    <!-- Logo — matches header exactly -->
    <a href="/" class="footer-logo-box">
      <img src="/logo.png" alt="The Standard" class="footer-logo-img" />
    </a>

    <!-- Center links -->
    <nav class="footer-nav">
      <a href="/" class="footer-link">Home</a>
      <a href="/archive" class="footer-link">Archive</a>
      <a href="/about" class="footer-link">About</a>
      <a href="mailto:thestandardblogpost@gmail.com" class="footer-link">Contact</a>
    </nav>

    <!-- Right -->
    <div class="footer-right">
      <span class="footer-location">Pune, India</span>
      <span class="footer-sep">·</span>
      <span class="footer-copy">© 2026 The<em>Standard</em></span>
    </div>

  </div>
</footer>

<style>
  .ts-footer {
    border-top: 0.5px solid #2A2A28;
    background: #141412;
    margin-top: 5rem;
  }
  .footer-bar {
    display: flex;
    align-items: center;
    justify-content: space-between;
    height: 64px;
    padding: 0 1.5rem;
  }

  /* Logo — same cream box as header */
  .footer-logo-box {
    background: #E8E2D6;
    padding: 4px 8px;
    display: flex;
    align-items: center;
    text-decoration: none;
    transition: opacity 0.2s;
    flex-shrink: 0;
  }
  .footer-logo-box:hover { opacity: 0.85; }
  .footer-logo-img {
    height: 28px;
    width: auto;
    display: block;
  }

  /* Nav */
  .footer-nav {
    display: flex;
    gap: 2rem;
    align-items: center;
  }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.08em;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #B8986A; }

  /* Right */
  .footer-right {
    display: flex;
    align-items: center;
    gap: 8px;
    flex-shrink: 0;
  }
  .footer-location {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .footer-sep {
    color: #333;
    font-size: 11px;
  }
  .footer-copy em {
    font-style: italic;
    color: #B8986A;
  }
  .footer-copy {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #888;
    letter-spacing: 0.04em;
  }

  /* Mobile */
  @media (max-width: 640px) {
    .footer-bar {
      flex-direction: column;
      height: auto;
      padding: 2rem 1.5rem;
      gap: 1.5rem;
      text-align: center;
    }
    .footer-nav { flex-wrap: wrap; justify-content: center; gap: 1rem; }
    .footer-right { justify-content: center; }
  }
</style>