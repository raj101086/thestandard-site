<footer class="ts-footer">
  <div class="footer-inner">

    <!-- Left — logo + tagline -->
    <div class="footer-left">
      <div class="footer-logo-box">
        <img src="/logo.png" alt="The Standard" class="footer-logo-img" />
      </div>
      <p class="footer-tagline">Things worth paying attention to.</p>
    </div>

    <!-- Center — nav links -->
    <nav class="footer-nav">
      <a href="/" class="footer-link">Home</a>
      <a href="/archive" class="footer-link">Archive</a>
      <a href="/about" class="footer-link">About</a>
      <a href="mailto:thestandardblogpost@gmail.com" class="footer-link">Contact</a>
    </nav>

    <!-- Right — location + copyright -->
    <div class="footer-right">
      <span class="footer-location">Pune, India</span>
      <span class="footer-copy">© 2026 The Standard</span>
    </div>

  </div>

  <!-- Bottom line -->
  <div class="footer-bottom">
    <span class="footer-bottom-text">Posted when something is genuinely worth sharing.</span>
  </div>
</footer>

<style>
  .ts-footer {
    border-top: 0.5px solid #2A2A28;
    margin-top: 5rem;
    background: #141412;
  }
  .footer-inner {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 4rem;
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    align-items: center;
    gap: 2rem;
  }

  /* Left */
  .footer-left {
    display: flex;
    flex-direction: column;
    gap: 10px;
  }
  .footer-logo-box {
    background: #E8E2D6;
    padding: 5px 12px;
    display: inline-block;
    width: fit-content;
  }
  .footer-logo-img {
    height: 22px;
    width: auto;
    display: block;
  }
  .footer-tagline {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #444;
    letter-spacing: 0.04em;
  }

  /* Center */
  .footer-nav {
    display: flex;
    flex-direction: column;
    gap: 8px;
    align-items: center;
  }
  .footer-link {
    font-family: var(--font-sans);
    font-size: 11px;
    letter-spacing: 0.1em;
    text-transform: uppercase;
    color: #555;
    text-decoration: none;
    transition: color 0.2s;
  }
  .footer-link:hover { color: #B8986A; }

  /* Right */
  .footer-right {
    display: flex;
    flex-direction: column;
    gap: 6px;
    align-items: flex-end;
  }
  .footer-location {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.15em;
    text-transform: uppercase;
    color: #B8986A;
  }
  .footer-copy {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #333;
    letter-spacing: 0.04em;
  }

  /* Bottom strip */
  .footer-bottom {
    border-top: 0.5px solid #1e1e1c;
    padding: 1rem 4rem;
    max-width: 1280px;
    margin: 0 auto;
  }
  .footer-bottom-text {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #2a2a28;
  }

  /* Responsive */
  @media (max-width: 768px) {
    .footer-inner {
      grid-template-columns: 1fr;
      padding: 2.5rem 1.5rem;
      gap: 2rem;
      text-align: center;
    }
    .footer-left { align-items: center; }
    .footer-right { align-items: center; }
    .footer-bottom { padding: 1rem 1.5rem; text-align: center; }
  }
</style>