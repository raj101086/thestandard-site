---
import menus from "@/collections/menu.json";
import Logo from "@/components/ui/Logo.astro";
---

<!-- Spacer so fixed header doesn't overlap content -->
<div class="relative w-full h-16 sm:h-20 opacity-0 pointer-events-none"></div>

<header id="header" class="fixed top-0 z-50 w-full">
  <div
    id="site-container"
    class="flex items-center justify-between h-16 sm:h-18 site-container mx-auto px-4 sm:px-6 border-b border-[#2A2A28] bg-[#1C1C1A] transition-all duration-300"
  >
    <!-- Logo -->
    <div class="flex-shrink-0 z-50">
      <Logo />
    </div>

    <!-- Mobile Menu Background Overlay -->
    <div
      id="mobileMenuBackground"
      class="fixed inset-0 z-20 hidden w-screen h-screen bg-[#1C1C1A]/95 backdrop-blur-sm"
    ></div>

    <!-- Navigation -->
    <nav class="relative z-30 flex flex-row-reverse justify-start w-full text-sm sm:justify-end sm:flex-row sm:items-center">

      <!-- Mobile Toggle -->
      <div class="flex items-center gap-2 sm:hidden">
        <div
          id="openMenu"
          class="flex items-center justify-center w-10 h-10 cursor-pointer transition-transform duration-200 active:scale-90"
        >
          <svg class="w-6 h-6 text-[#E8E2D6]" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M4 8h16M4 16h16"></path>
          </svg>
        </div>
        <div
          id="closeMenu"
          class="hidden items-center justify-center w-10 h-10 cursor-pointer transition-transform duration-200 active:scale-90"
        >
          <svg class="w-5 h-5 text-[#E8E2D6]" fill="none" stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" viewBox="0 0 24 24" stroke="currentColor">
            <path d="M6 18L18 6M6 6l12 12"></path>
          </svg>
        </div>
      </div>

      <!-- Menu Items -->
      <div
        id="menu"
        class="fixed top-16 left-0 right-0 ease-out duration-300 z-40 flex-col items-center justify-start hidden w-auto h-auto pt-8 pb-6 sm:py-0 sm:relative sm:top-0 sm:flex-row sm:flex sm:h-auto"
      >
        <!-- Mobile Menu Background -->
        <div class="absolute inset-0 block sm:hidden">
          <div class="relative w-full h-full bg-[#1C1C1A] border-b border-[#2A2A28]"></div>
        </div>

        <!-- Links -->
        <div class="relative z-10 flex flex-col sm:flex-row items-center w-full sm:w-auto gap-1 sm:gap-0">
          {menus.map((menu) => (
            <a
              href={menu.url}
              class="nav-link relative flex items-center justify-center w-full sm:w-auto px-5 py-3 sm:py-2 sm:px-4 font-medium tracking-wide text-center text-[#888] hover:text-[#E8E2D6] transition-colors duration-200 text-sm"
            >
              {menu.name}
            </a>
          ))}
        </div>

        <!-- Mobile Connect Button -->
        <div class="relative z-10 w-full px-6 mt-4 sm:hidden">
          <a
            href="mailto:thestandardblogpost@gmail.com"
            class="block text-center text-xs tracking-[0.12em] uppercase border border-[#3a3a38] text-[#E8E2D6] px-6 py-3 hover:border-[#B8986A] hover:text-[#B8986A] transition-colors duration-200"
          >
            Connect
          </a>
        </div>
      </div>

      <!-- Desktop Connect -->
      <div class="relative hidden sm:flex items-center gap-6 ml-8">
        <a
          href="mailto:thestandardblogpost@gmail.com"
          class="text-xs tracking-[0.1em] uppercase text-[#666] hover:text-[#B8986A] transition-colors duration-200"
        >
          Connect
        </a>
        <a
          href="/subscribe"
          class="text-xs tracking-[0.1em] uppercase bg-[#B8986A] text-[#111] px-5 py-2.5 font-semibold hover:bg-[#D4B078] transition-colors duration-200"
        >
          Subscribe
        </a>
      </div>

    </nav>
  </div>
</header>

<style>
  #header {
    transition: all 0.3s cubic-bezier(0.4, 0, 0.2, 1);
  }

  /* Gold underline on hover — desktop only */
  @media (min-width: 640px) {
    .nav-link::after {
      content: '';
      position: absolute;
      bottom: 0;
      left: 50%;
      transform: translateX(-50%) scaleX(0);
      width: 60%;
      height: 1px;
      background: #B8986A;
      transition: transform 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    .nav-link:hover::after {
      transform: translateX(-50%) scaleX(1);
    }
  }

  @media (max-width: 639px) {
    #menu {
      transform: translateY(-8px);
      opacity: 0;
      pointer-events: none;
      transition: all 0.25s cubic-bezier(0.4, 0, 0.2, 1);
    }
    #menu:not(.hidden) {
      transform: translateY(0);
      opacity: 1;
      pointer-events: auto;
    }
    body { overflow-x: hidden; }
    button, a, [role="button"] { -webkit-tap-highlight-color: transparent; }
  }
</style>

<script>
  const openMenu  = document.getElementById('openMenu');
  const closeMenu = document.getElementById('closeMenu');
  const menu      = document.getElementById('menu');
  const bg        = document.getElementById('mobileMenuBackground');

  function openMobileMenu() {
    menu?.classList.remove('hidden');
    bg?.classList.remove('hidden');
    openMenu?.classList.add('hidden');
    closeMenu?.classList.remove('hidden');
    closeMenu?.classList.add('flex');
    document.body.style.overflow = 'hidden';
  }

  function closeMobileMenu() {
    menu?.classList.add('hidden');
    bg?.classList.add('hidden');
    closeMenu?.classList.add('hidden');
    closeMenu?.classList.remove('flex');
    openMenu?.classList.remove('hidden');
    document.body.style.overflow = '';
  }

  openMenu?.addEventListener('click', openMobileMenu);
  closeMenu?.addEventListener('click', closeMobileMenu);
  bg?.addEventListener('click', closeMobileMenu);

  menu?.querySelectorAll('a').forEach(link => {
    link.addEventListener('click', () => {
      if (window.innerWidth < 640) closeMobileMenu();
    });
  });

  window.addEventListener('resize', () => {
    if (window.innerWidth >= 640) {
      document.body.style.overflow = '';
      menu?.classList.remove('hidden');
    }
  });
</script>