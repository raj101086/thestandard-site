---
import Layout from "@/layouts/Layout.astro";
import { getCollection } from "astro:content";

const allPosts = await getCollection("post");

const posts = allPosts
  .sort((a, b) => b.data.publishDate.valueOf() - a.data.publishDate.valueOf())
  .map(post => ({
    id: post.id,
    title: post.data.title,
    description: post.data.description,
    publishDate: post.data.publishDate,
    tags: post.data.tags || [],
    img: post.data.img,
    img_alt: post.data.img_alt,
    link: `/blog/${post.id}`,
    featured: post.data.featured || false,
  }));

const categories = [
  "Fashion", "Motorcycles", "Film & Series", "Music",
  "Photography", "Books", "Coffee & Food", "Travel", "Watches"
];

// Group posts by first tag
const postsByCategory: Record<string, typeof posts> = {};
const uncategorized: typeof posts = [];

for (const post of posts) {
  if (post.tags.length > 0) {
    const cat = post.tags[0];
    if (!postsByCategory[cat]) postsByCategory[cat] = [];
    postsByCategory[cat].push(post);
  } else {
    uncategorized.push(post);
  }
}

const formattedDate = (date: Date) =>
  new Date(date).toLocaleDateString('en-US', {
    year: 'numeric', month: 'short', day: 'numeric'
  });
---

<Layout title="Archive — The Standard">

  <!-- PAGE HEADER -->
  <div class="archive-header">
    <div class="archive-header-inner">
      <div class="archive-eyebrow">Archive</div>
      <h1 class="archive-title font-brand">Everything, in order.</h1>
      <p class="archive-desc">All posts across every category — filtered by topic, sorted by date.</p>
    </div>
  </div>

  <!-- CATEGORY FILTER TABS -->
  <div class="filter-wrap">
    <div class="filter-tabs">
      <button class="filter-tab active" data-filter="all">All</button>
      {categories.map(cat => (
        <button class="filter-tab" data-filter={cat}>{cat}</button>
      ))}
    </div>
  </div>

  <!-- POST LIST -->
  <div class="archive-body">

    <!-- ALL POSTS (flat list, shown when "All" active) -->
    <div class="post-list" id="list-all">
      {posts.length === 0 ? (
        <div class="empty-state">
          <span class="empty-label">No posts yet</span>
          <p class="empty-desc">Check back soon — posts are on the way.</p>
        </div>
      ) : (
        posts.map((post, i) => (
          <a href={post.link} class="post-row" data-tags={post.tags.join(",")}>
            <span class="post-row-index">{String(i + 1).padStart(2, "0")}</span>
            <span class="post-row-cat">{post.tags[0] || "—"}</span>
            <span class="post-row-title font-brand">{post.title}</span>
            <span class="post-row-date">{formattedDate(post.publishDate)}</span>
            <span class="post-row-arrow">→</span>
          </a>
        ))
      )}
    </div>

    <!-- CATEGORY SECTIONS (shown when a specific category is active) -->
    {categories.map(cat => {
      const catPosts = postsByCategory[cat] || [];
      return (
        <div class="category-section hidden" id={`cat-${cat.replace(/[^a-z0-9]/gi, '-').toLowerCase()}`}>
          <div class="cat-section-header">
            <span class="cat-section-label">{cat}</span>
            <div class="cat-section-line"></div>
            <span class="cat-section-count">{catPosts.length} {catPosts.length === 1 ? 'post' : 'posts'}</span>
          </div>
          {catPosts.length === 0 ? (
            <div class="empty-state">
              <span class="empty-label">Nothing here yet</span>
              <p class="empty-desc">Posts in {cat} are coming soon.</p>
            </div>
          ) : (
            catPosts.map((post, i) => (
              <a href={post.link} class="post-row">
                <span class="post-row-index">{String(i + 1).padStart(2, "0")}</span>
                <span class="post-row-cat">{cat}</span>
                <span class="post-row-title font-brand">{post.title}</span>
                <span class="post-row-date">{formattedDate(post.publishDate)}</span>
                <span class="post-row-arrow">→</span>
              </a>
            ))
          )}
        </div>
      );
    })}

  </div>

</Layout>

<style>
  /* ── PAGE HEADER ───────────────────────────────────────────────── */
  .archive-header {
    border-bottom: 0.5px solid #2a2a28;
    padding: 5rem 4rem 4rem;
  }
  .archive-header-inner { max-width: 600px; }
  .archive-eyebrow {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #B8986A;
    margin-bottom: 1.25rem;
  }
  .archive-title {
    font-size: clamp(36px, 4vw, 52px);
    line-height: 1.1;
    font-weight: normal;
    color: #E8E2D6;
    margin-bottom: 1rem;
  }
  .archive-desc {
    font-family: var(--font-sans);
    font-size: 13px;
    line-height: 1.8;
    color: #666;
  }

  /* ── FILTER TABS ───────────────────────────────────────────────── */
  .filter-wrap {
    border-bottom: 0.5px solid #2a2a28;
    overflow-x: auto;
    scrollbar-width: none;
  }
  .filter-wrap::-webkit-scrollbar { display: none; }
  .filter-tabs {
    display: flex;
    padding: 0 4rem;
    min-width: max-content;
  }
  .filter-tab {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #555;
    padding: 14px 18px 12px;
    background: none;
    border: none;
    border-bottom: 2px solid transparent;
    cursor: pointer;
    white-space: nowrap;
    transition: color 0.15s;
  }
  .filter-tab:hover { color: #999; }
  .filter-tab.active {
    color: #E8E2D6;
    border-bottom: 2px solid #B8986A;
  }

  /* ── BODY ──────────────────────────────────────────────────────── */
  .archive-body {
    max-width: 1280px;
    margin: 0 auto;
    padding: 3rem 4rem 6rem;
  }

  /* ── POST ROW ──────────────────────────────────────────────────── */
  .post-row {
    display: grid;
    grid-template-columns: 36px 120px 1fr auto 24px;
    align-items: center;
    gap: 1.5rem;
    padding: 1.25rem 0;
    border-bottom: 0.5px solid #222220;
    text-decoration: none;
    transition: background 0.15s;
  }
  .post-row:first-child { border-top: 0.5px solid #222220; }
  .post-row:hover { background: #1e1e1c; padding-left: 8px; padding-right: 8px; margin: 0 -8px; }
  .post-row:hover .post-row-title { color: #B8986A; }
  .post-row:hover .post-row-arrow { color: #B8986A; opacity: 1; }

  .post-row-index {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #333;
    letter-spacing: 0.08em;
  }
  .post-row-cat {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.12em;
    text-transform: uppercase;
    color: #B8986A;
    white-space: nowrap;
  }
  .post-row-title {
    font-size: 18px;
    font-weight: normal;
    color: #E8E2D6;
    line-height: 1.3;
    transition: color 0.15s;
  }
  .post-row-date {
    font-family: var(--font-sans);
    font-size: 11px;
    color: #444;
    white-space: nowrap;
    letter-spacing: 0.04em;
  }
  .post-row-arrow {
    font-size: 14px;
    color: #333;
    opacity: 0;
    transition: color 0.15s, opacity 0.15s;
  }

  /* ── CATEGORY SECTION HEADER ───────────────────────────────────── */
  .cat-section-header {
    display: flex;
    align-items: center;
    gap: 1rem;
    margin-bottom: 0;
    padding: 2rem 0 0;
  }
  .cat-section-label {
    font-family: var(--font-sans);
    font-size: 10px;
    letter-spacing: 0.22em;
    text-transform: uppercase;
    color: #555;
    white-space: nowrap;
  }
  .cat-section-line {
    flex: 1;
    height: 0.5px;
    background: #2a2a28;
  }
  .cat-section-count {
    font-family: var(--font-sans);
    font-size: 10px;
    color: #444;
    letter-spacing: 0.08em;
  }

  /* ── EMPTY STATE ───────────────────────────────────────────────── */
  .empty-state {
    padding: 3rem 0;
    border-top: 0.5px solid #222220;
  }
  .empty-label {
    font-family: var(--font-brand);
    font-size: 20px;
    color: #333;
    display: block;
    margin-bottom: 0.5rem;
  }
  .empty-desc {
    font-family: var(--font-sans);
    font-size: 12px;
    color: #444;
  }

  .hidden { display: none !important; }

  /* ── RESPONSIVE ────────────────────────────────────────────────── */
  @media (max-width: 768px) {
    .archive-header { padding: 3rem 1.5rem 2.5rem; }
    .filter-tabs { padding: 0 1.5rem; }
    .archive-body { padding: 2rem 1.5rem 4rem; }
    .post-row {
      grid-template-columns: 28px 1fr auto;
      gap: 0.75rem;
    }
    .post-row-cat { display: none; }
    .post-row-arrow { display: none; }
    .post-row-date { font-size: 10px; }
  }
</style>

<script>
  const tabs = document.querySelectorAll<HTMLButtonElement>('.filter-tab');
  const listAll = document.getElementById('list-all');
  const catSections = document.querySelectorAll<HTMLElement>('.category-section');

  tabs.forEach(tab => {
    tab.addEventListener('click', () => {
      // Update active tab
      tabs.forEach(t => t.classList.remove('active'));
      tab.classList.add('active');

      const filter = tab.dataset.filter;

      if (filter === 'all') {
        listAll?.classList.remove('hidden');
        catSections.forEach(s => s.classList.add('hidden'));
      } else {
        listAll?.classList.add('hidden');
        catSections.forEach(s => s.classList.add('hidden'));
        const id = `cat-${filter!.replace(/[^a-z0-9]/gi, '-').toLowerCase()}`;
        document.getElementById(id)?.classList.remove('hidden');
      }
    });
  });
</script>